# App
APP_ENV=development
APP_NAME=expense-tracker-on-chain

# Backend
API_HOST=0.0.0.0
API_PORT=8080
EXPENSES_PG_ENABLED=true
AUTH_PG_ENABLED=true
HYBRID_ONCHAIN_ENABLED=false
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN_SECONDS=3600
REFRESH_EXPIRES_IN_SECONDS=604800
CLEANUP_INTERVAL_SECONDS=30

# Database/Cache
DATABASE_URL=postgres://postgres:postgres@localhost:5432/expense_tracker
REDIS_URL=redis://localhost:6379

# Blockchain (Solana)
# Localnet default for free local development
SOLANA_RPC_URL=http://127.0.0.1:8899
SOLANA_COMMITMENT=finalized
# Program ID after local deploy (`pnpm run deploy:localnet`)
SOLANA_PROGRAM_ID=ReplaceWithDeployedProgramId
PROGRAM_ID=ReplaceWithDeployedProgramId
# Local/dev wallet private key. Never commit this value to git.
WALLET_PRIVATE_KEY=replace_with_local_wallet_private_key

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SOLANA_CLUSTER=localnet
# Must match PROGRAM_ID above
NEXT_PUBLIC_PROGRAM_ID=ReplaceWithDeployedProgramId
